<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Humble Bundle UI</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous">
    <style>
      body { background-color: #f8f9fa; }
      .bundle-card { transition: transform 0.15s ease-in-out, box-shadow 0.15s ease-in-out; }
      .bundle-card:hover { transform: translateY(-3px); box-shadow: 0 6px 16px rgba(0,0,0,0.15) !important; }
      .bundle-card.not-downloaded { border-color: #ffc107 !important; border-width: 2px !important; }
      .bundle-card.downloaded { border-color: #198754 !important; opacity: 0.8; }
      #download-output { min-height: 80px; }
    </style>
  </head>

  <body>
    <%= yield %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>
    <script src="/assets/application.js" defer></script>
  </body>
</html>
